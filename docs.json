{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Advocora Help Center",
  "description": "Guides and how-tos for Advocora — the advocacy CRM for nonprofits. Manage contacts, gifts, email campaigns, forms, and more.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Changelog",
          "icon": "scroll-text",
          "href": "https://www.mintlify.com/docs/changelog"
        },
        {
          "anchor": "Help",
          "icon": "life-buoy",
          "href": "https://www.mintlify.com/docs/contact-support"
        }
      ]
    },
    "directory": "card",
    "pages": [
      "index.mdx",
      {
        "group": "Contacts",
        "icon": "users",
        "pages": [
          "contacts/overview.mdx",
          "contacts/find-contacts.mdx",
          "contacts/add-a-contact.mdx",
          "contacts/manage-a-contact.mdx",
          "contacts/donor-status.mdx",
          "contacts/bulk-actions.mdx"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Open Advocora",
      "href": "https://app.advocora.io"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/advocora",
      "linkedin": "https://linkedin.com/company/advocora"
    }
  }
}
