{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Advocora Help Center",
  "description": "Guides and how-tos for Advocora — the advocacy CRM for nonprofits. Manage contacts, gifts, email campaigns, forms, and more.",
  "colors": {
    "primary": "#D57447",
    "light": "#E89265",
    "dark": "#B35025"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "directory": "card",
    "pages": [
      "index",
      {
        "group": "Contacts",
        "icon": "users",
        "pages": [
          "contacts/overview",
          "contacts/find-contacts",
          "contacts/add-a-contact",
          "contacts/manage-a-contact",
          "contacts/donor-status",
          "contacts/bulk-actions"
        ]
      }
    ]
  },
  "logo": {
    "light": "data:image/png;base64,",
    "dark": "data:image/png;base64,"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Open Advocora",
      "href": "https://app.advocora.io"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/advocora",
      "linkedin": "https://linkedin.com/company/advocora"
    }
  },
  "background": {
    "color": {
      "light": "#FAF5ED",
      "dark": "#070D17"
    }
  },
  "fonts": {
    "heading": {
      "family": "Newsreader"
    },
    "body": {
      "family": "Inter"
    }
  }
}
